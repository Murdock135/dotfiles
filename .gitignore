# Ignore everything by default
*

# Track specific dotfiles
!.profile
!.bashrc
!.zshrc
!.vimrc
!.gitconfig
!.gitignore
!.tmux.conf
!dotfiles_init.sh

!install_scripts/
!install_scripts/*

# Include .config directory itself
!.config/

# But ignore everything inside .config by default
.config/*

# Track specific config directories
!.config/nvim/
!.config/nvim/**
!.config/nvim.bak
!.config/nvim.bak/**
!.config/.oh-my-bash-custom/
!.config/.oh-my-bash-custom/**

# IMPORTANT: Ignore the bare repository itself
Documents/code/personal_repos/.dotfiles

